  "CutsceneData.Cutscene.1000013.1": {
    "ko": "똑똑, 똑똑!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.2": {
    "ko": "편지 왔어요!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.3": {
    "ko": "먼저 받으시는 분 성함을 확인할께요.",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.4": {
    "ko": "새턴…",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.6": {
    "ko": "새턴 위치우드씨..? \n제가 맞게 찾아왔길 바랍니다..",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.7": {
    "ko": "맞다면 여기, 등기로 온 문서가 있으니 서명해주시겠어요?",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.8": {
    "ko": "어떤…아! 마법소녀 통신 스쿨의 수료증!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.9": {
    "ko": "맞아! 세번째 시도만에 합격이야!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.10": {
    "ko": "축하드립니다!\n이제 어엿한 마법소녀라고 할 수 있겠네요.",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.11": {
    "ko": "신비한 재료 역학 과목은 꼼짝없이 과락일 줄 알았어..",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.12": {
    "ko": "마법기계 제도의 기초나.. 그리고… 실용 수학도요…",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.13": {
    "ko": "저런! 위험했네요!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.14": {
    "ko": "그치만 리본&레이스 연금술이나 마녀의 디저트 베이킹은 틀림없이 최고였을걸요!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.15": {
    "ko": "그랬으리라 믿어 의심치 않아요.",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.16": {
    "ko": "서명은 여기다 하면 되죠?",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.19": {
    "ko": "짜잔!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.20": {
    "ko": "확실히 받았습니다.\n귀여운 마법봉이네요!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.21": {
    "ko": "헤헤... 아르바이트로 번 돈을 모조리 쏟아부었거든요…",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.22": {
    "ko": "덕분에 빈털터리예요..",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.23": {
    "ko": "그랬군요! 이제 정식으로 마법을 사용할 수 있으니 훌륭한 일자리를 구할 거예요.",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.24": {
    "ko": "마법으로 돌아가는 공장을 차리면 일을 안해도 금을 갈퀴로 쓸어모은다죠? 경력을 쌓아서 마법산업청에 들어가면 명예와 권력을 한 손에 쥘 수도 있고요!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.25": {
    "ko": "아아! 마법사의 재능이란 아름다워라!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.26": {
    "ko": "그래서 당신은 앞으로 무슨 일을 할 건가요, 마법소녀 새턴?",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.27": {
    "ko": "아르바이트! 더 많은 아르바이트를 할 거예요!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.28": {
    "ko": "...삐삑?!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.29": {
    "ko": "아차, 실수로 모국어로 말해버렸네요.\n그래요. 음. 아르바이트.",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.30": {
    "ko": "그럼 서명은 잘 받았고... 여기, 당신 앞으로 온 편지들이에요.",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.31": {
    "ko": "고마워요!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.32": {
    "ko": "그럼, 파트타임 마법소녀! 멋진 인생이 되길!",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000013.35": {
    "ko": "날아갔다…",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000033.1": {
    "ko": "뭘 살거임?",
    "en": "",
    "ja": ""
  },
  "CutsceneData.Cutscene.1000034.1": {
    "ko": "아티팩트가 없다!",
